{
  "name": "hubassist-backend",
  "version": "0.1.0",
  "description": "HubAssist NestJS REST API",
  "scripts": {
    "start:dev": "nest start --watch",
    "build": "nest build",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "test": "jest --config jest.config.ts",
    "test:watch": "jest --config jest.config.ts --watch",
    "test:cov": "jest --config jest.config.ts --coverage",
    "test:e2e": "jest --config jest-e2e.config.ts",
    "validate-env": "node scripts/validate-env.js",
    "seed:bookings": "ts-node scripts/seed-bookings.ts"
  },
  "dependencies": {
    "@nestjs-modules/mailer": "^2.3.6",
    "@nestjs/cache-manager": "^3.1.2",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^10.0.0",
    "@nestjs/jwt": "^10.0.0",
    "@nestjs/passport": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/platform-socket.io": "^11.1.24",
    "@nestjs/swagger": "^7.1.0",
    "@nestjs/terminus": "^10.3.0",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^10.0.0",
    "@nestjs/websockets": "^11.1.24",
    "@simplewebauthn/server": "^13.3.0",
    "@stellar/stellar-sdk": "^15.0.1",
    "@types/multer": "^2.1.0",
    "bcrypt": "^5.1.0",
    "cache-manager": "^5.7.6",
    "cache-manager-ioredis-yet": "^2.1.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "cloudinary": "^2.5.1",
    "compression": "^1.8.1",
    "handlebars": "^4.7.9",
    "helmet": "^8.1.0",
    "ioredis": "^5.11.0",
    "joi": "^18.1.2",
    "nest-winston": "^1.10.2",
    "nodemailer": "^8.0.10",
    "passport-jwt": "^4.0.1",
    "pg": "^8.11.0",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.0",
    "socket.io": "^4.8.3",
    "typeorm": "^0.3.17",
    "rrule": "2.8.1",
    "uuid": "^10.0.0",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^10.4.22",
    "@types/bcrypt": "^5.0.0",
    "@types/compression": "^1.8.1",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.19.39",
    "@types/nodemailer": "^8.0.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.57.1",
    "jest": "^29.7.0",
    "prettier": "^3.8.3",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^5.0.0"
  }
}
